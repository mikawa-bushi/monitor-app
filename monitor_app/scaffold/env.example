# 環境ごとに変わる設定。このファイルを .env にコピーして編集する。
# 値は config.py ではなくここに置く(特にパスワード)。

# --- データベース接続 ---
# SQLite(既定):
MONITOR_DATABASE_URL=sqlite:///instances/database.db
# MySQL の例:
# MONITOR_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/monitor_app
# PostgreSQL の例:
# MONITOR_DATABASE_URL=postgresql+pg8000://user:password@localhost:5432/monitor_app

# --- サーバー ---
MONITOR_HOST=127.0.0.1
MONITOR_PORT=9990

# --- 認証(任意)---
# 設定すると書き込み系 API に X-API-Key ヘッダが必須になる。
# MONITOR_API_KEY=change-me
# 読み取り系も保護する場合:
# MONITOR_PROTECT_READS=true

# --- 自動データ取り込み(センサ/PLC が CSV を更新する場合)---
# csv/ フォルダを監視して変更を自動取り込み:
# MONITOR_INGEST_WATCH=true
# MONITOR_INGEST_INTERVAL=5
# 取り込みモード replace(置換) / append(追記・時系列向き):
# MONITOR_INGEST_MODE=replace

# --- アラート通知先(config.py の AlertRule の notify で指定したチャネル)---
# MONITOR_WEBHOOK_URL=https://hooks.slack.com/services/XXX
# MONITOR_LINE_TOKEN=xxxxx
# MONITOR_SMTP_HOST=smtp.example.com
# MONITOR_SMTP_PORT=587
# MONITOR_SMTP_USER=alert@example.com
# MONITOR_SMTP_PASSWORD=xxxxx
# MONITOR_ALERT_EMAIL_TO=line-lead@example.com

# --- 監査ログ(変更履歴。/api/audit で閲覧)---
# MONITOR_AUDIT_ENABLED=true

# --- その他 ---
# MONITOR_LOG_LEVEL=INFO
# MONITOR_CSV_DIR=csv
